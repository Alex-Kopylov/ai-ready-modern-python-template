{
  // markdownlint-cli2 configuration
  // Uses .markdownlint.jsonc for rules, this file for CLI options
  // See: https://github.com/DavidAnson/markdownlint-cli2

  // Suppress verbose discovery output
  "noBanner": true,
  "noProgress": true,

  // Paths to lint
  "globs": [
    "*.md",
    ".claude/**/*.md",
    ".codex/**/*.md",
    ".github/**/*.md",
    "docs/**/*.md",
    "README.md",
    "CLAUDE.md",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "LICENSE.md",
    "CODE_OF_CONDUCT.md",
    "CHANGELOG.md"
  ],

  // Exclusions (working documents, build artifacts)
  "ignores": [
    ".claude/.tmp/**",
    ".claude/plans/**",
    ".venv/**",
    "goals/**",
    "node_modules/**",
    "build/**",
    "dist/**",
    "docs/specs/**",
    "docs/internal/**",
    ".claude/tests/hooks/results/archive/**"
  ]
}
